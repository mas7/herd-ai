# LLM
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# User Profile
USER_DISPLAY_NAME=YourName

# Database (override for production)
DATABASE_URL=sqlite+aiosqlite:///./data/herd.db

# ── Arize Phoenix (self-hosted via docker-compose) ─────────────────────────
# Run setup.sh first, then: docker compose up
# Open http://localhost:6006 — no account needed
PHOENIX_COLLECTOR_ENDPOINT=http://localhost:6006/v1/traces
PHOENIX_PROJECT_NAME=herd-ai

# ── Mission Control (agent orchestration dashboard) ────────────────────────
# Open http://localhost:3010 after docker compose up
MC_AUTH_USER=admin
MC_AUTH_PASS=changeme
MC_AUTH_SECRET=changeme-secret
MC_API_KEY=changeme-api-key
# URL the API uses to reach Mission Control (Docker: http://mission-control:3000, local: http://localhost:3010)
MC_BASE_URL=http://localhost:3010
# Set to true to enable Herd AI department monitoring in Mission Control
NEXT_PUBLIC_HERD_MODE=true

# GrowthBook
GROWTHBOOK_CLIENT_KEY=sdk-...

# Voice Model (path to fine-tuned model)
VOICE_MODEL_PATH=./data/voice_model
